{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Dhi13man/harness-evals/blob/main/holdout-plan.schema.json",
  "$defs": {
    "adapterBinding": {
      "additionalProperties": false,
      "properties": {
        "adapter_id": {
          "pattern": "^[a-z0-9][a-z0-9._-]*$",
          "type": "string"
        },
        "authority_scope": {
          "enum": [
            "diagnostic",
            "production",
            "test"
          ]
        },
        "binding_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        "capability_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        "config_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        "contract_revision": {
          "minimum": 1,
          "type": "integer"
        },
        "role": {
          "enum": [
            "comparison",
            "generation"
          ]
        },
        "runtime_provenance_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        }
      },
      "required": [
        "adapter_id",
        "authority_scope",
        "binding_sha256",
        "capability_sha256",
        "config_sha256",
        "contract_revision",
        "role",
        "runtime_provenance_sha256"
      ],
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "comparator_calibration_evidence_sha256": {
      "oneOf": [
        {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "comparator_release_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "comparator_profile_id": {
      "minLength": 1,
      "type": "string"
    },
    "comparator_profile_descriptor_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "comparator_profile_authority_registry_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "candidate_commit": {
      "pattern": "^[0-9a-f]{40}$",
      "type": "string"
    },
    "cases": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "case_tree_sha256": {
            "pattern": "^[0-9a-f]{64}$",
            "type": "string"
          },
          "shared_tree_sha256": {
            "oneOf": [
              {
                "pattern": "^[0-9a-f]{64}$",
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "release_case_fingerprint": {
            "pattern": "^[0-9a-f]{64}$",
            "type": "string"
          },
          "critical_expectations": {
            "items": {
              "minLength": 1,
              "pattern": "^[a-z0-9][a-z0-9._-]*$",
              "type": "string"
            },
            "minItems": 1,
            "type": "array",
            "uniqueItems": true
          },
          "id": {
            "pattern": "^[a-z0-9][a-z0-9._-]*$",
            "type": "string"
          },
          "skill": {
            "pattern": "^[a-z0-9][a-z0-9-]*$",
            "type": "string"
          }
        },
        "required": [
          "id",
          "case_tree_sha256",
          "shared_tree_sha256",
          "release_case_fingerprint",
          "skill",
          "critical_expectations"
        ],
        "type": "object"
      },
      "minItems": 1,
      "type": "array"
    },
    "comparison_profile": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "comparator_order": {
            "minLength": 1,
            "type": "string"
          },
          "control": {
            "pattern": "^[a-z0-9][a-z0-9._-]*$",
            "type": "string"
          },
          "id": {
            "pattern": "^[a-z0-9][a-z0-9._-]*$",
            "type": "string"
          },
          "repetitions": {
            "minimum": 1,
            "type": "integer"
          },
          "treatment": {
            "pattern": "^[a-z0-9][a-z0-9._-]*$",
            "type": "string"
          }
        },
        "required": [
          "id",
          "control",
          "treatment",
          "repetitions",
          "comparator_order"
        ],
        "type": "object"
      },
      "minItems": 1,
      "type": "array"
    },
    "generator_provider": {
      "additionalProperties": false,
      "properties": {
        "executable_sha256": {
          "oneOf": [
            {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "reasoning_effort": {
          "oneOf": [
            {
              "enum": [
                "low",
                "medium",
                "high",
                "xhigh",
                "max",
                "ultra"
              ]
            },
            {
              "type": "null"
            }
          ]
        },
        "billing_basis": {
          "enum": [
            "metered_api",
            "chatgpt_subscription"
          ]
        },
        "protocol_lock": {
          "oneOf": [
            {
              "minLength": 1,
              "pattern": "^(?!/)(?!\\./)(?!.*//)(?!.*(?:^|/)\\.\\.?(/|$))(?!.*\\/$).+$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "protocol_lock_sha256": {
          "oneOf": [
            {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "execution_policy": {
          "oneOf": [
            {
              "additionalProperties": false,
              "properties": {
                "concurrency": {
                  "const": "concurrent"
                },
                "release_authoritative": {
                  "const": true
                }
              },
              "required": [
                "concurrency",
                "release_authoritative"
              ],
              "type": "object"
            },
            {
              "additionalProperties": false,
              "properties": {
                "concurrency": {
                  "const": "serialized"
                },
                "release_authoritative": {
                  "const": false
                }
              },
              "required": [
                "concurrency",
                "release_authoritative"
              ],
              "type": "object"
            }
          ]
        },
        "name": {
          "minLength": 1,
          "type": "string"
        },
        "requested_model": {
          "minLength": 1,
          "type": "string"
        },
        "version": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "name",
        "version",
        "requested_model",
        "executable_sha256",
        "reasoning_effort",
        "billing_basis",
        "protocol_lock",
        "protocol_lock_sha256",
        "execution_policy"
      ],
      "allOf": [
        {
          "if": {
            "properties": {
              "billing_basis": {
                "const": "metered_api"
              }
            },
            "required": [
              "billing_basis"
            ]
          },
          "then": {
            "properties": {
              "reasoning_effort": {
                "type": "null"
              },
              "protocol_lock": {
                "type": "null"
              },
              "protocol_lock_sha256": {
                "type": "null"
              },
              "execution_policy": {
                "properties": {
                  "concurrency": {
                    "const": "concurrent"
                  },
                  "release_authoritative": {
                    "const": true
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "billing_basis": {
                "const": "chatgpt_subscription"
              }
            },
            "required": [
              "billing_basis"
            ]
          },
          "then": {
            "properties": {
              "requested_model": {
                "enum": [
                  "gpt-5.6-luna",
                  "gpt-5.6-terra"
                ]
              },
              "executable_sha256": {
                "type": "string"
              },
              "reasoning_effort": {
                "type": "string"
              },
              "protocol_lock": {
                "type": "string"
              },
              "protocol_lock_sha256": {
                "type": "string"
              },
              "execution_policy": {
                "properties": {
                  "concurrency": {
                    "const": "serialized"
                  },
                  "release_authoritative": {
                    "const": false
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "billing_basis": {
                "const": "chatgpt_subscription"
              },
              "requested_model": {
                "const": "gpt-5.6-luna"
              }
            },
            "required": [
              "billing_basis",
              "requested_model"
            ]
          },
          "then": {
            "properties": {
              "reasoning_effort": {
                "enum": [
                  "low",
                  "medium",
                  "high",
                  "xhigh",
                  "max"
                ]
              }
            }
          }
        }
      ],
      "type": "object"
    },
    "generator_adapter_binding": {
      "$ref": "#/$defs/adapterBinding",
      "properties": {
        "role": {
          "const": "generation"
        }
      }
    },
    "comparator_adapter_binding": {
      "$ref": "#/$defs/adapterBinding",
      "properties": {
        "role": {
          "const": "comparison"
        }
      }
    },
    "manifest_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "evaluation_mode": {
      "enum": [
        "judged",
        "objective_only"
      ]
    },
    "objective_acceptance_policy_id": {
      "pattern": "^[a-z0-9][a-z0-9._-]*$",
      "type": "string"
    },
    "objective_acceptance_policy_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "original_commit": {
      "pattern": "^[0-9a-f]{40}$",
      "type": "string"
    },
    "source_bindings": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "kind": {
            "enum": [
              "git_ref",
              "without_skill",
              "worktree"
            ]
          },
          "source_commit": {
            "oneOf": [
              {
                "pattern": "^(?:[0-9a-f]{40}|[0-9a-f]{64})$",
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "source_sha256_by_case": {
            "additionalProperties": {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            "minProperties": 1,
            "propertyNames": {
              "pattern": "^[a-z0-9][a-z0-9._-]*$"
            },
            "type": "object"
          },
          "variant_id": {
            "pattern": "^[a-z0-9][a-z0-9._-]*$",
            "type": "string"
          }
        },
        "required": [
          "variant_id",
          "kind",
          "source_commit",
          "source_sha256_by_case"
        ],
        "allOf": [
          {
            "if": {
              "properties": {
                "kind": {
                  "const": "without_skill"
                }
              },
              "required": [
                "kind"
              ]
            },
            "then": {
              "properties": {
                "source_commit": {
                  "type": "null"
                }
              }
            },
            "else": {
              "properties": {
                "source_commit": {
                  "type": "string"
                }
              }
            }
          }
        ],
        "type": "object"
      },
      "minItems": 1,
      "type": "array"
    },
    "consumption_record_path": {
      "minLength": 1,
      "pattern": "^/",
      "type": "string"
    },
    "plan_id": {
      "pattern": "^[a-z0-9][a-z0-9._-]*$",
      "type": "string"
    },
    "provenance": {
      "additionalProperties": false,
      "properties": {
        "assurance": {
          "const": "trusted-reviewed-attestation"
        },
        "freeze_record": {
          "minLength": 1,
          "type": "string"
        },
        "frozen_before_candidate_evaluation": {
          "const": true
        },
        "privacy_claim": {
          "const": "not-a-cryptographic-privacy-proof"
        },
        "reviewed_by": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "minItems": 1,
          "type": "array",
          "uniqueItems": true
        },
        "seal_record": {
          "minLength": 1,
          "type": "string"
        },
        "sealed_after_independent_review": {
          "const": true
        }
      },
      "required": [
        "assurance",
        "privacy_claim",
        "frozen_before_candidate_evaluation",
        "sealed_after_independent_review",
        "reviewed_by",
        "freeze_record",
        "seal_record"
      ],
      "type": "object"
    },
    "schema_version": {
      "enum": [
        2,
        3,
        4
      ]
    },
    "seed": {
      "minimum": 0,
      "type": "integer"
    },
    "status": {
      "const": "sealed"
    }
  },
  "required": [
    "schema_version",
    "plan_id",
    "status",
    "manifest_sha256",
    "generator_provider",
    "consumption_record_path",
    "seed",
    "comparison_profile",
    "cases",
    "provenance"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "schema_version": {
            "const": 4
          }
        },
        "required": [
          "schema_version"
        ]
      },
      "then": {
        "required": [
          "generator_adapter_binding"
        ],
        "allOf": [
          {
            "if": {
              "properties": {
                "evaluation_mode": {
                  "const": "judged"
                }
              },
              "required": [
                "evaluation_mode"
              ]
            },
            "then": {
              "required": [
                "comparator_adapter_binding"
              ]
            },
            "else": {
              "not": {
                "required": [
                  "comparator_adapter_binding"
                ]
              }
            }
          }
        ]
      },
      "else": {
        "not": {
          "anyOf": [
            {
              "required": [
                "generator_adapter_binding"
              ]
            },
            {
              "required": [
                "comparator_adapter_binding"
              ]
            }
          ]
        }
      }
    }
  ],
  "oneOf": [
    {
      "not": {
        "anyOf": [
          {
            "required": [
              "source_bindings"
            ]
          },
          {
            "required": [
              "evaluation_mode"
            ]
          },
          {
            "required": [
              "comparator_profile_id"
            ]
          },
          {
            "required": [
              "comparator_profile_descriptor_sha256"
            ]
          },
          {
            "required": [
              "comparator_profile_authority_registry_sha256"
            ]
          },
          {
            "required": [
              "objective_acceptance_policy_id"
            ]
          },
          {
            "required": [
              "objective_acceptance_policy_sha256"
            ]
          },
          {
            "required": [
              "generator_adapter_binding"
            ]
          },
          {
            "required": [
              "comparator_adapter_binding"
            ]
          }
        ]
      },
      "properties": {
        "schema_version": {
          "const": 2
        }
      },
      "required": [
        "candidate_commit",
        "original_commit",
        "comparator_release_sha256",
        "comparator_calibration_evidence_sha256"
      ]
    },
    {
      "not": {
        "anyOf": [
          {
            "required": [
              "candidate_commit"
            ]
          },
          {
            "required": [
              "original_commit"
            ]
          },
          {
            "required": [
              "objective_acceptance_policy_id"
            ]
          },
          {
            "required": [
              "objective_acceptance_policy_sha256"
            ]
          }
        ]
      },
      "properties": {
        "evaluation_mode": {
          "const": "judged"
        },
        "schema_version": {
          "enum": [
            3,
            4
          ]
        }
      },
      "required": [
        "source_bindings",
        "evaluation_mode",
        "comparator_release_sha256",
        "comparator_calibration_evidence_sha256",
        "comparator_profile_id",
        "comparator_profile_descriptor_sha256",
        "comparator_profile_authority_registry_sha256"
      ]
    },
    {
      "not": {
        "anyOf": [
          {
            "required": [
              "candidate_commit"
            ]
          },
          {
            "required": [
              "original_commit"
            ]
          },
          {
            "required": [
              "comparator_release_sha256"
            ]
          },
          {
            "required": [
              "comparator_calibration_evidence_sha256"
            ]
          },
          {
            "required": [
              "comparator_profile_id"
            ]
          },
          {
            "required": [
              "comparator_profile_descriptor_sha256"
            ]
          },
          {
            "required": [
              "comparator_profile_authority_registry_sha256"
            ]
          }
        ]
      },
      "properties": {
        "evaluation_mode": {
          "const": "objective_only"
        },
        "schema_version": {
          "enum": [
            3,
            4
          ]
        }
      },
      "required": [
        "source_bindings",
        "evaluation_mode",
        "objective_acceptance_policy_id",
        "objective_acceptance_policy_sha256"
      ]
    }
  ],
  "title": "Harness Evals sealed holdout plan",
  "type": "object"
}
