{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Dhi13man/harness-evals/blob/main/suite.schema.json",
  "title": "Harness Evals instruction-bundle suite",
  "description": "Manifest for isolated, blinded instruction-bundle evaluations through registered agent-harness providers.",
  "oneOf": [
    {
      "$ref": "#/$defs/suiteV2"
    },
    {
      "$ref": "#/$defs/suiteV3"
    }
  ],
  "$defs": {
    "suiteV2": {
      "$ref": "#/$defs/suiteBase",
      "required": [
        "comparator"
      ],
      "properties": {
        "schema_version": {
          "const": 2
        },
        "cases": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/judgedCase"
          }
        }
      },
      "not": {
        "anyOf": [
          {
            "required": [
              "evaluation_mode"
            ]
          },
          {
            "required": [
              "comparator_profile"
            ]
          }
        ]
      }
    },
    "suiteV3": {
      "$ref": "#/$defs/suiteBase",
      "required": [
        "evaluation_mode"
      ],
      "properties": {
        "schema_version": {
          "const": 3
        },
        "evaluation_mode": {
          "enum": [
            "judged",
            "objective_only"
          ]
        },
        "comparator_profile": {
          "$ref": "#/$defs/comparatorProfile"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "evaluation_mode": {
                "const": "judged"
              }
            },
            "required": [
              "evaluation_mode"
            ]
          },
          "then": {
            "required": [
              "comparator",
              "comparator_profile"
            ],
            "properties": {
              "cases": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "$ref": "#/$defs/judgedCase"
                }
              }
            }
          },
          "else": {
            "not": {
              "anyOf": [
                {
                  "required": [
                    "comparator"
                  ]
                },
                {
                  "required": [
                    "comparator_profile"
                  ]
                }
              ]
            },
            "properties": {
              "cases": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "$ref": "#/$defs/objectiveCase"
                }
              }
            }
          }
        }
      ]
    },
    "suiteBase": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "suite_id",
        "seed",
        "repository_root",
        "provider",
        "variants",
        "comparisons",
        "cases"
      ],
      "properties": {
        "$schema": {
          "type": "string"
        },
        "schema_version": {},
        "evaluation_mode": {},
        "suite_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]*$"
        },
        "seed": {
          "type": "integer",
          "minimum": 0
        },
        "repository_root": {
          "$ref": "#/$defs/relativePath"
        },
        "provider": {
          "$ref": "#/$defs/provider"
        },
        "comparator": {
          "$ref": "#/$defs/comparatorProvider"
        },
        "comparator_profile": {},
        "variants": {
          "type": "array",
          "minItems": 2,
          "items": {
            "$ref": "#/$defs/variant"
          }
        },
        "comparisons": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/comparison"
          }
        },
        "cases": {
          "type": "array",
          "minItems": 1
        }
      }
    },
    "comparatorProvider": {
      "allOf": [
        {
          "$ref": "#/$defs/provider"
        },
        {
          "not": {
            "properties": {
              "kind": {
                "const": "codex"
              }
            },
            "required": [
              "kind"
            ]
          }
        }
      ]
    },
    "comparatorProfile": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "id"
          ],
          "properties": {
            "kind": {
              "const": "builtin"
            },
            "id": {
              "enum": [
                "software-engineering-v2.3",
                "plain-language-revision-v1"
              ]
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "path"
          ],
          "properties": {
            "kind": {
              "const": "suite_local"
            },
            "path": {
              "$ref": "#/$defs/suiteFilePath"
            }
          }
        }
      ]
    },
    "identifier": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "$comment": "The runner resolves this relative to the field's declared root. Case paths and context paths may not escape; repository and worktree roots may use parent traversal."
    },
    "suiteFilePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!\\./)(?!.*//)(?!.*(?:^|/)\\.\\.?(/|$))(?!.*\\/$).+$"
    },
    "provider": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "model",
        "timeout_seconds"
      ],
      "properties": {
        "kind": {
          "enum": [
            "claude",
            "codex",
            "fake"
          ]
        },
        "executable": {
          "type": "string",
          "minLength": 1
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "max_budget_usd": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "reasoning_effort": {
          "enum": [
            "low",
            "medium",
            "high",
            "xhigh",
            "max",
            "ultra"
          ]
        },
        "billing_basis": {
          "enum": [
            "metered_api",
            "chatgpt_subscription"
          ]
        },
        "protocol_lock": {
          "$ref": "#/$defs/suiteFilePath"
        },
        "timeout_seconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3600
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "claude"
              }
            }
          },
          "then": {
            "required": [
              "executable",
              "max_budget_usd"
            ],
            "properties": {
              "billing_basis": {
                "const": "metered_api"
              }
            },
            "not": {
              "anyOf": [
                {
                  "required": [
                    "reasoning_effort"
                  ]
                },
                {
                  "required": [
                    "protocol_lock"
                  ]
                }
              ]
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "fake"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "billing_basis": {
                "const": "metered_api"
              }
            },
            "not": {
              "anyOf": [
                {
                  "required": [
                    "reasoning_effort"
                  ]
                },
                {
                  "required": [
                    "protocol_lock"
                  ]
                }
              ]
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "codex"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "required": [
              "executable",
              "reasoning_effort",
              "billing_basis",
              "protocol_lock"
            ],
            "properties": {
              "model": {
                "enum": [
                  "gpt-5.6-luna",
                  "gpt-5.6-terra"
                ]
              },
              "billing_basis": {
                "const": "chatgpt_subscription"
              }
            },
            "not": {
              "required": [
                "max_budget_usd"
              ]
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "codex"
              },
              "model": {
                "const": "gpt-5.6-luna"
              }
            },
            "required": [
              "kind",
              "model"
            ]
          },
          "then": {
            "properties": {
              "reasoning_effort": {
                "enum": [
                  "low",
                  "medium",
                  "high",
                  "xhigh",
                  "max"
                ]
              }
            }
          }
        }
      ]
    },
    "variant": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "id",
            "kind"
          ],
          "properties": {
            "id": {
              "$ref": "#/$defs/identifier"
            },
            "kind": {
              "const": "without_skill"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "id",
            "kind",
            "git_ref"
          ],
          "properties": {
            "id": {
              "$ref": "#/$defs/identifier"
            },
            "kind": {
              "const": "git_ref"
            },
            "git_ref": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "id",
            "kind",
            "root",
            "source_ref"
          ],
          "properties": {
            "id": {
              "$ref": "#/$defs/identifier"
            },
            "kind": {
              "const": "worktree"
            },
            "root": {
              "$ref": "#/$defs/relativePath"
            },
            "source_ref": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ]
    },
    "comparison": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "control",
        "treatment",
        "repetitions",
        "comparator_order"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "control": {
          "$ref": "#/$defs/identifier"
        },
        "treatment": {
          "$ref": "#/$defs/identifier"
        },
        "repetitions": {
          "const": 3
        },
        "comparator_order": {
          "const": "ab_ba"
        }
      }
    },
    "caseBase": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "skill",
        "split",
        "prompt_file",
        "fixture_dir",
        "verifier",
        "context_files",
        "timeout_seconds",
        "critical_expectations"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "skill": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "split": {
          "enum": [
            "train",
            "validation",
            "holdout"
          ]
        },
        "prompt_file": {
          "$ref": "#/$defs/relativePath"
        },
        "fixture_dir": {
          "$ref": "#/$defs/relativePath"
        },
        "verifier": {
          "$ref": "#/$defs/verifier"
        },
        "context_files": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/relativePath"
          },
          "uniqueItems": true
        },
        "timeout_seconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3600
        },
        "critical_expectations": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/identifier"
          },
          "uniqueItems": true
        },
        "comparator_contract": {
          "$ref": "#/$defs/comparatorContract"
        }
      }
    },
    "judgedCase": {
      "allOf": [
        {
          "$ref": "#/$defs/caseBase"
        },
        {
          "required": [
            "comparator_contract"
          ]
        }
      ]
    },
    "objectiveCase": {
      "allOf": [
        {
          "$ref": "#/$defs/caseBase"
        },
        {
          "not": {
            "required": [
              "comparator_contract"
            ]
          }
        }
      ]
    },
    "comparatorContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requirements",
        "performance_basis",
        "qualitative_bases"
      ],
      "properties": {
        "requirements": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "kind", "text"],
            "properties": {
              "id": {"$ref": "#/$defs/identifier"},
              "kind": {"$ref": "#/$defs/identifier"},
              "text": {"type": "string", "minLength": 20}
            }
          }
        },
        "performance_basis": {
          "oneOf": [
            {"type": "null"},
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["kind", "detail"],
              "properties": {
                "kind": {"$ref": "#/$defs/identifier"},
                "detail": {"type": "string", "minLength": 20}
              }
            }
          ]
        },
        "qualitative_bases": {
          "type": "object",
          "propertyNames": {"$ref": "#/$defs/identifier"},
          "additionalProperties": {"$ref": "#/$defs/qualitativeBasis"}
        }
      }
    },
    "qualitativeBasis": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "detail"],
      "properties": {
        "kind": {"$ref": "#/$defs/identifier"},
        "detail": {"type": "string", "minLength": 20}
      }
    },
    "verifier": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "argv",
        "timeout_seconds",
        "required_tools"
      ],
      "properties": {
        "argv": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "timeout_seconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3600
        },
        "required_tools": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._+-]*$"
          },
          "uniqueItems": true
        }
      }
    }
  }
}
